# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/tododjs

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Configuration — Resend (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=TodoDJs <noreply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com

# Frontend URL
FRONTEND_URL=http://localhost:5174

# File Upload
MAX_FILE_SIZE=50000000
UPLOAD_PATH=./uploads

# ── BPM & Key Detection (pick one or both, priority: Spotify > AudD > Essentia) ──

# Option A: AudD.io — audio fingerprinting + metadata (free: 500 req/month)
# Register at https://dashboard.audd.io
AUDD_API_TOKEN=your_audd_api_token

# Option B: Spotify Web API — same data as Tunebat (free developer app, no Premium needed)
# Note: audio-features endpoint may be restricted on apps created after Nov 2024
# Register at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
